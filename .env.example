# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
RATE_LIMIT_MAX=240
RATE_LIMIT_AUTH_MAX=30
DATA_BACKEND=sqlite
OBJECT_STORE_BACKEND=local
ENABLE_REQUEST_LOGS=0

# PostgreSQL (when DATA_BACKEND=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=10

# AI provider (optional)
# If omitted, API endpoints fall back to deterministic heuristic logic.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
