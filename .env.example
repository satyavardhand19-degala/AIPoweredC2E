# Server
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
RATE_LIMIT_MAX=240
RATE_LIMIT_AUTH_MAX=30
ENABLE_REQUEST_LOGS=0

# Backend Selection
# DATA_BACKEND: sqlite (default), json, postgres
DATA_BACKEND=sqlite
# OBJECT_STORE_BACKEND: local (default), s3
OBJECT_STORE_BACKEND=local
# RATE_LIMIT_BACKEND: in-process (default), redis
RATE_LIMIT_BACKEND=in-process
# SESSION_BACKEND: in-process (default), redis
SESSION_BACKEND=in-process
# ENABLE_ASYNC_JOBS: 0 (default), 1 (requires worker.mjs + redis)
ENABLE_ASYNC_JOBS=0

# PostgreSQL (when DATA_BACKEND=postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=10

# Managed Object Storage (when OBJECT_STORE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Redis (when RATE_LIMIT_BACKEND=redis or SESSION_BACKEND=redis or ENABLE_ASYNC_JOBS=1)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI provider (optional)
# If omitted, API endpoints fall back to deterministic heuristic logic.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
